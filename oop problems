class battery:
    def __init__(self, battery_size):
        self.battery=battery_size
    def describe_battery(self):
        return self.battery
    def upgrade_battery(self):
        if self.battery != 65 :
            self.battery = 65
    def get_range(self):
        if self.battery == 40:
            return f"it can go 150 miles"
        elif self.battery == 65:
            return f"it can go 225 miles"        


            
class electriccar(car):
    def __init__(self,make,model,year,odometer_reading=0,battery_size=40):
        super().__init__(model,year,odometer_reading)
        self.battery_info=battery(battery_size)

